{
  "name": "freightdesk-api",
  "version": "1.0.0",
  "description": "FreightDesk external API — holds Supabase keys server-side",
  "private": true,
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "check-env": "node scripts/check-env.js",
    "seed:admin": "node scripts/seed-admin-user.js",
    "download:containers": "node scripts/download-all-containers.js",
    "convert:cookies": "node scripts/convert-cookies.js",
    "postinstall": "node -e \"require('express'); require('cors'); require('jsonwebtoken'); require('ws');\""
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "express": "^4.22.2",
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.18.3"
  },
  "engines": {
    "node": ">=18"
  }
}
