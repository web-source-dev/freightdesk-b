# FreightDesk API — server-side secrets only (do NOT ship to desktop clients)
APP_NAME=FreightDesk
APP_COMPANY=FreightDesk

API_PORT=3850
FREIGHTDESK_API_URL=https://freightdesk.rtnglobal.co
API_JWT_SECRET=change-me-in-production

# User database (login)
USER_SUPABASE_URL=
USER_SUPABASE_SERVICE_KEY=

# Session / proxy / DAT infrastructure
SESSION_SUPABASE_URL=
SESSION_SUPABASE_SERVICE_KEY=
SESSION_SUPABASE_ANON_KEY=

# Optional seed defaults (npm run seed:admin)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=Admin@FreightDesk2026
# ADMIN_CONTAINER=A
# USER_SUPABASE_DB_PASSWORD=

# Bulk session download (npm run download:containers)
# Uses local storage credentials by default; set FREIGHTDESK_API_URL for remote API mode

# Partner integration (DATHUB backend)
# DATHUB_PARTNER_API_KEY=generate-a-long-random-secret

# Legacy fallbacks (optional)
# SUPABASE_URL=
# SUPABASE_SERVICE_KEY=
# SUPABASE_ANON_KEY=
